# Example .env for KALU | BHAI
# Copy this to .env and fill with real values (DO NOT commit .env)

# Discord webhooks
DISCORD_HOOK_SUBDOMAINS=
DISCORD_HOOK_WAYBACK=
DISCORD_HOOK_ENRICHMENT=
DISCORD_HOOK_REPORT = 
# API keys
